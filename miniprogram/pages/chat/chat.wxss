.page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.settings,
.composer,
.message {
  border: 1rpx solid #d8dee8;
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 12rpx 36rpx rgba(22, 32, 51, 0.08);
}

.settings {
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.profile-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14rpx;
  margin-top: 14rpx;
}

.location-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 16rpx;
}

.location-text {
  color: #667085;
  font-size: 24rpx;
}

.field {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.label {
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
}

.input,
.picker {
  min-height: 72rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 12rpx;
  background: #f8fafc;
  font-size: 26rpx;
  line-height: 72rpx;
  box-sizing: border-box;
}

.chat {
  height: calc(100vh - 430rpx);
  min-height: 520rpx;
}

.empty {
  margin: 80rpx 20rpx;
  padding: 28rpx;
  border: 1rpx dashed #d8dee8;
  border-radius: 16rpx;
  color: #667085;
  text-align: center;
  line-height: 1.6;
}

.message {
  max-width: 92%;
  margin-bottom: 20rpx;
  padding: 20rpx;
  line-height: 1.65;
}

.message.user {
  margin-left: auto;
  background: #eaf2ff;
  border-color: rgba(31, 111, 235, 0.18);
}

.message.assistant {
  margin-right: auto;
}

.role {
  margin-bottom: 8rpx;
  color: #344054;
  font-size: 24rpx;
  font-weight: 800;
}

.content {
  white-space: pre-wrap;
  font-size: 28rpx;
}

.thinking {
  color: #667085;
}

.cards {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.card {
  padding: 18rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 14rpx;
  background: #f8fafc;
}

.card-title,
.group-title,
.source-title {
  margin-bottom: 8rpx;
  color: #162033;
  font-weight: 800;
}

.desc {
  color: #344054;
  font-size: 26rpx;
  line-height: 1.6;
}

.meta {
  margin-top: 8rpx;
  color: #667085;
  font-size: 24rpx;
}

.url {
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: rgba(22, 32, 51, 0.05);
  color: #667085;
  font-size: 22rpx;
  word-break: break-all;
}

.link-button {
  display: inline-flex;
  margin: 12rpx 12rpx 0 0;
  background: #1f6feb;
  color: #ffffff;
  font-weight: 700;
}

.link-button.ghost {
  background: #ffffff;
  color: #1f6feb;
  border: 1rpx solid rgba(31, 111, 235, 0.28);
}

.button-line {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.group {
  margin-top: 16rpx;
}

.check-row {
  display: grid;
  grid-template-columns: 40rpx 1fr auto;
  gap: 12rpx;
  align-items: center;
  margin-top: 10rpx;
  padding: 14rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 12rpx;
  background: #ffffff;
}

.box {
  width: 34rpx;
  height: 34rpx;
  border: 2rpx solid #1f6feb;
  border-radius: 8rpx;
  color: #1f6feb;
  text-align: center;
  line-height: 32rpx;
  font-weight: 800;
}

.check-text {
  color: #344054;
  font-size: 25rpx;
  line-height: 1.5;
}

.checked .check-text {
  color: #667085;
  text-decoration: line-through;
}

.priority {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: rgba(102, 112, 133, 0.12);
  color: #667085;
  font-size: 20rpx;
  font-weight: 800;
}

.priority.high {
  background: rgba(194, 65, 53, 0.12);
  color: #c24135;
}

.priority.medium {
  background: rgba(161, 92, 7, 0.12);
  color: #a15c07;
}

.priority.low {
  background: rgba(15, 159, 143, 0.12);
  color: #047857;
}

.steps {
  margin-top: 12rpx;
}

.route-map {
  width: 100%;
  height: 360rpx;
  margin-bottom: 14rpx;
  border-radius: 14rpx;
  overflow: hidden;
}

.card-warning {
  margin-bottom: 12rpx;
  color: #a15c07;
  font-size: 24rpx;
  line-height: 1.5;
}

.tour-row {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: #ffffff;
}

.tour-index {
  flex: 0 0 36rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  background: #1f6feb;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 800;
  line-height: 36rpx;
  text-align: center;
}

.tour-body {
  min-width: 0;
  flex: 1;
}

.tour-tips {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 12rpx;
  background: rgba(31, 111, 235, 0.08);
}

.tip {
  margin-top: 6rpx;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

.step,
.dining-row {
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: #ffffff;
  color: #344054;
  font-size: 24rpx;
  line-height: 1.5;
}

.composer {
  margin-top: 18rpx;
  padding: 18rpx;
}

.textarea {
  width: 100%;
  min-height: 92rpx;
  padding: 16rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 12rpx;
  background: #f8fafc;
  box-sizing: border-box;
}

.actions {
  display: flex;
  justify-content: flex-end;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}

.model-picker {
  flex: 1;
  min-width: 0;
}

.model-picker-view {
  min-height: 70rpx;
  padding: 0 18rpx;
  border: 1rpx solid #d8dee8;
  border-radius: 12rpx;
  background: #ffffff;
  color: #344054;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 70rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.primary,
.secondary {
  min-width: 150rpx;
  border-radius: 12rpx;
  font-weight: 800;
}

.secondary.small {
  min-width: 180rpx;
  margin: 0;
}

.primary {
  background: #1f6feb;
  color: #ffffff;
}

.primary.danger {
  background: #c24135;
}

.secondary {
  background: #ffffff;
  color: #344054;
  border: 1rpx solid #d8dee8;
}

.error {
  margin-bottom: 10rpx;
  color: #c24135;
  font-size: 24rpx;
}
